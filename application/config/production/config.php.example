$config['cookie_httponly']  = FALSE;
$config['cookie_samesite']  = $is_https ? 'None' : 'Lax';

/*
  |--------------------------------------------------------------------------
  | Standardize newlines
  |--------------------------------------------------------------------------
 */
$config['standardize_newlines'] = FALSE;

/*
  |--------------------------------------------------------------------------
  | Global XSS Filtering
  |--------------------------------------------------------------------------
 */
