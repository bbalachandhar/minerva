/*
  |--------------------------------------------------------------------------
  | Session Variables
  |--------------------------------------------------------------------------
 */
$config['sess_driver'] = 'files';
$config['sess_cookie_name'] = 'ci_session';

// TRUE for HTTPS production deployments (always true in production/)
