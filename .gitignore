# ----------------------------------------------------------------------
# A clean .gitignore for this CodeIgniter project
# ----------------------------------------------------------------------

# Ignore CodeIgniter generated directories
# These should be created on the server with correct permissions
# Directory itself is tracked via .gitkeep — runtime files inside are ignored.
/application/cache/*
!/application/cache/.gitkeep
/application/logs/*
!/application/logs/.gitkeep
/application/sessions/*
!/application/sessions/.gitkeep
/application/tmp/**
!/application/tmp/.gitkeep

# Ignore API CodeIgniter runtime directories
/api/application/cache/*
!/api/application/cache/.gitkeep
/api/application/logs/*
!/api/application/logs/.gitkeep
/api/application/sessions/*
!/api/application/sessions/.gitkeep

# Ignore environment-specific configurations (contains sensitive data)
/application/config/production/*
!/application/config/production/*.example

# Instance-specific configs — each deployment has its own copy.
# Track *.example versions instead (no credentials, placeholder values).
/application/config/database.php
/application/config/config.php

# Uploads — ignore all actual files but track directory structure via .gitkeep
# git pull on any instance will NEVER touch uploaded files (images, docs, etc.)
uploads/**/*
!uploads/**/.gitkeep

# Ignore temporary, backup, and local config files
/temp/
/backup/
.env

# IDE and OS-specific files
.idea/
.vscode/
nbproject/
.DS_Store
Thumbs.db

# Track backend folder but ignore specific dynamic content
!/backend/

# Ignore dynamically generated files in backend
/backend/captcha_images/
/backend/plugins/ckeditor/plugins/ckeditor_wiris/cache/
/backend/report/

/.github

# API environment-specific configs
api/application/config/config.php
api/application/config/database.php
api/application/config/autoload.php

# Ignore non-code files (brochures, reports, office docs, local csv exports)
*.docx
*.pptx
*.bak
*.bak_*
dist/
"minerva logos/"

# Data import/export files — never commit raw data, cleaned CSVs, or xlsx dumps
# Root-level data files
/*.xlsx
/*.csv

# tools/ data files (sql migration scripts are intentionally tracked)
tools/*.xlsx
tools/*.csv
tools/~$*

# backend/import — ignore all CSVs except app-provided sample/template files
backend/import/*.csv
!backend/import/*sample*.csv
!backend/import/*csvfile.csv
!backend/import/*template.csv
