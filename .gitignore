# ----------------------------------------------------------------------
# A clean .gitignore for this CodeIgniter project
# ----------------------------------------------------------------------

# Ignore CodeIgniter generated directories
# These should be created on the server with correct permissions
/application/cache/
/application/logs/
/application/sessions/

# Ignore environment-specific configurations (contains sensitive data)
/application/config/production/

# Ignore user-uploaded content
/uploads/

# Ignore temporary, backup, and local config files
/temp/
/backup/
.env

# IDE and OS-specific files
.idea/
.vscode/
nbproject/
.DS_Store
Thumbs.db

# Ignore backend captcha images
/backend/captcha_images/
/backend
/.github
uploads/
